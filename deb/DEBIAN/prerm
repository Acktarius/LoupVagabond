#!/bin/bash
# Make sure this script doesn't fail even if there are errors
set -e

echo "LoupVagabond pre-removal script running..."

# Stop only the launcher itself using exact process name.
# Avoid -f matching, which can accidentally match apt/dpkg command lines.
if pgrep -x loupvagabond > /dev/null; then
    echo "Stopping running loupvagabond process..."
    pkill -x loupvagabond || true
    sleep 1
    pkill -9 -x loupvagabond 2>/dev/null || true
fi

# Ensure any symlinks are removed in case they're causing issues
if [ -L /usr/bin/loupvagabond ]; then
    echo "Removing symlink..."
    rm -f /usr/bin/loupvagabond || true
fi

echo "Pre-removal completed successfully."
exit 0
